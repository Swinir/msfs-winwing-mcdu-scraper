mcdu:
  captain:
    enabled: true
  
  copilot:
    enabled: false

mobiflight:
  captain_url: "ws://localhost:8320/winwing/cdu-captain"
  copilot_url: "ws://localhost:8320/winwing/cdu-co-pilot"
  font: "AirbusThales"
  max_retries: 3

performance:
  capture_fps: 30
  enable_caching: true

# OCR settings (optional — sensible defaults are used if omitted)
# ocr:
#   # Template matching threshold (0.0–1.0).  Lower = more permissive.
#   template_threshold: 0.78
#   # EasyOCR confidence floor.  Detections below this are discarded.
#   easyocr_min_confidence: 0.15
